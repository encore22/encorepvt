# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
FIREBASE_CREDENTIALS_PATH=/app/credentials/firebase-key.json

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_ID=your-admin-telegram-user-id

# Encryption (32-byte base64 key - generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())")
ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# Device Farm
MAX_CONCURRENT_DEVICES=6
JOB_TIMEOUT_MINUTES=10
DEVICE_CREATION_RETRIES=3

# Service URLs (set after deployment)
DEVICE_MANAGER_URL=https://device-manager-xxx-uc.a.run.app
DEVICE_AUTOMATION_URL=https://device-automation-xxx-uc.a.run.app
TELEGRAM_BOT_URL=https://telegram-bot-xxx-uc.a.run.app

# TOTP generation: set to 1 to never send secrets to 2fa.live (local pyotp only)
# TOTP_USE_LOCAL_ONLY=1

# Firestore Emulator (local testing only - remove in production)
# FIRESTORE_EMULATOR_HOST=localhost:8080
